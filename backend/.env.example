# Sao chép file này thành .env và chỉnh cho phù hợp môi trường của bạn.

# Kết nối PostgreSQL (local dùng pgAdmin: tạo sẵn database "learning3d")
# Định dạng: postgresql+psycopg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/learning3d

# Bảo mật JWT
SECRET_KEY=doi-thanh-chuoi-bi-mat-that-dai-va-ngau-nhien
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS: origin của frontend (Vite dev mặc định 5173)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Connection pool (mỗi worker giữ pool riêng):
# WEB_CONCURRENCY(workers) * DB_POOL_SIZE phải <= Postgres max_connections (mặc định 100)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Tài khoản admin hệ thống tạo tự động khi seed
FIRST_ADMIN_EMAIL=admin@3dlearning.vn
FIRST_ADMIN_PASSWORD=admin123
